# LLM
LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=
EMBEDDING_MODEL=text-embedding-v3

# Backward-compatible alias. Keep empty if LLM_API_KEY is used.
DASHSCOPE_API_KEY=

JWT_SECRET=change-me-in-production
